# ===== 발급 완료 =====
# Finnhub (해외 시세)
FINNHUB_API_KEY=

# DART (국내 재무/공시)
DART_API_KEY=

# 네이버 뉴스 검색 API
NAVER_CLIENT_ID=
NAVER_CLIENT_SECRET=

# FRED (VIX 등 매크로 지표)
FRED_API_KEY=

# ===== 추후 발급 (지금은 비워둬도 됨) =====
# KIS Developers (국내 실시간 시세) - 키를 넣는 순간 kis_collector가 자동 활성화됨
KIS_APP_KEY=
KIS_APP_SECRET=
KIS_ACCOUNT_NO=

# ===== DB =====
# Supabase 대시보드 > Project Settings > Database > Connection string (URI)
DATABASE_URL=postgresql://postgres:[YOUR-PASSWORD]@[YOUR-HOST]:5432/postgres
